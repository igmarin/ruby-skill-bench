#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'
require_relative '../lib/agent_eval'

options = {
  mode: 'simple',
  template: 'service_object',
  format: 'human',
  force: false,
  skill: 'default',
  provider: 'openai'
}

OptionParser.new do |opts|
  opts.banner = 'Usage: agent-eval [command] [options]'

  opts.on('-h', '--help', 'Show this help message') do
    puts opts
    exit
  end

  opts.on('--rails', 'Use Rails-specific configuration') do
    options[:rails] = true
  end

  opts.on('--ci', 'Output in CI format (JSON/JUnit)') do
    options[:format] = 'json'
  end

  opts.on('--mode MODE', 'Skill mode: simple, advanced, rails') do |mode|
    options[:mode] = mode
  end

  opts.on('--template TEMPLATE', 'Rails template: service_object, concern, active_record_model') do |template|
    options[:template] = template
  end

  opts.on('--force', 'Force overwrite existing files') do
    options[:force] = true
  end

  opts.on('--skill SKILL', 'Skill name to use') do |skill|
    options[:skill] = skill
  end

  opts.on('--provider PROVIDER', 'Provider name to use') do |provider|
    options[:provider] = provider
  end
end.parse!

# Handle subcommands like 'skill new', 'eval new'
first_arg = ARGV.shift
second_arg = ARGV[0]

command = if second_arg && %w[new].include?(second_arg)
            "#{first_arg} #{ARGV.shift}"
          else
            first_arg
          end

case command
when 'init'
  begin
    AgentEval::Commands::Init.run(rails: options[:rails], force: options[:force])
    puts 'Initialized .agent-eval.yml'
  rescue RuntimeError => e
    puts e.message
    exit 1
  end
when 'skill', 'skill new'
  name = ARGV.shift
  AgentEval::Commands::SkillNew.run(name: name, mode: options[:mode], template: options[:template])
  puts "Created skill: #{name}"
when 'eval', 'eval new'
  name = ARGV.shift
  AgentEval::Commands::EvalNew.run(name: name, runtime: options[:rails] ? 'rails' : 'generic')
  puts "Created eval: #{name}"
when 'run'
  eval_name = ARGV.shift
  result = AgentEval::Commands::Run.run(
    eval_name: eval_name,
    skill_name: options[:skill],
    provider_name: options[:provider]
  )
  puts AgentEval::OutputFormatter.format(result, format: options[:format].to_sym)
  exit AgentEval::OutputFormatter.exit_code(result)
else
  puts 'Unknown command. Use: init, skill new, eval new, run'
  exit 1
end
